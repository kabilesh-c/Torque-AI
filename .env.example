# ─────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─────────────────────────────────────────
# Auth
# ─────────────────────────────────────────
JWT_SECRET="replace-with-a-random-32-char-string"

# ─────────────────────────────────────────
# OpenAI (fast model: gpt-4o-mini, quality: gpt-4o)
# Note: You can also use OPENROUTER_API_KEY instead of OPENAI_API_KEY
# ─────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENROUTER_API_KEY="sk-or-v1-..."

# ─────────────────────────────────────────
# Vapi (Voice AI layer)
# ─────────────────────────────────────────
VAPI_API_KEY="your-vapi-server-api-key"
NEXT_PUBLIC_VAPI_API_KEY="your-vapi-public-api-key"

# ─────────────────────────────────────────
# App URL (used for Vapi webhook callback)
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
